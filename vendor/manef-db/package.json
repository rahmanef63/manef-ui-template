{
  "name": "@manef/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.9.0"
  },
  "exports": {
    "./api": {
      "types": "./api.d.ts",
      "default": "./api.js"
    },
    "./dataModel": {
      "types": "./dataModel.d.ts",
      "default": "./api.js"
    },
    "./errors": {
      "types": "./errors.d.ts",
      "default": "./errors.js"
    },
    "./permissions": {
      "types": "./permissions.d.ts",
      "default": "./api.js"
    },
    "./workspaces": {
      "types": "./workspaces.d.ts",
      "default": "./workspaces.js"
    }
  },
  "files": [
    "api.d.ts",
    "api.js",
    "convex",
    "dataModel.d.ts",
    "errors.d.ts",
    "errors.js",
    "permissions.d.ts",
    "shared",
    "workspaces.d.ts",
    "workspaces.js"
  ],
  "scripts": {
    "dev": "convex dev --typecheck=disable",
    "codegen": "convex codegen",
    "deploy": "convex deploy",
    "deploy:ci": "convex deploy -y",
    "test:smoke": "python3 scripts/smoke_dashboard_features.py",
    "sync:runtime": "python3 scripts/sync_openclaw_runtime_to_convex.py",
    "sync:runtime:agents": "python3 scripts/sync_openclaw_agents_to_convex.py",
    "sync:runtime:workspaces": "python3 scripts/sync_openclaw_workspaces_to_convex.py",
    "sync:runtime:sessions": "python3 scripts/sync_openclaw_sessions_to_convex.py",
    "sync:runtime:config": "python3 scripts/sync_openclaw_config_to_convex.py",
    "sync:runtime:crons": "python3 scripts/sync_openclaw_crons_to_convex.py",
    "sync:runtime:skills": "python3 scripts/sync_openclaw_skills_to_convex.py",
    "sync:runtime:channels": "python3 scripts/sync_openclaw_channels_to_convex.py",
    "sync:runtime:logs": "python3 scripts/sync_openclaw_logs_to_convex.py",
    "sync:runtime:nodes": "python3 scripts/sync_openclaw_nodes_to_convex.py"
  },
  "dependencies": {
    "convex": "^1.31.6",
    "convex-ents": "^0.18.1",
    "convex-helpers": "^0.1.27",
    "resend": "^6.8.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "typescript": "^5.7.0"
  }
}
