# Public domains exposed by Dokploy / Traefik
CONVEX_API_DOMAIN=dbgg.<YOUR_DOMAIN>
CONVEX_SITE_DOMAIN=dbggsite.<YOUR_DOMAIN>
CONVEX_DASHBOARD_DOMAIN=dbggdash.<YOUR_DOMAIN>

# URLs consumed by the Convex backend/dashboard
CONVEX_CLOUD_ORIGIN=https://dbgg.<YOUR_DOMAIN>
CONVEX_SITE_ORIGIN=https://dbggsite.<YOUR_DOMAIN>
NEXT_PUBLIC_DEPLOYMENT_URL=https://dbgg.<YOUR_DOMAIN>

# Required secret for self-hosted backend
INSTANCE_NAME=manef-db
INSTANCE_SECRET=replace-with-long-random-secret

# Optional production backing stores
POSTGRES_URL=
MYSQL_URL=
DATABASE_URL=

# Optional S3-compatible storage config
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_ENDPOINT_URL=
S3_STORAGE_EXPORTS_BUCKET=
S3_STORAGE_FILES_BUCKET=
S3_STORAGE_MODULES_BUCKET=
S3_STORAGE_SEARCH_BUCKET=
S3_STORAGE_SNAPSHOT_IMPORTS_BUCKET=

# Optional tuning
DISABLE_BEACON=
DISABLE_METRICS_ENDPOINT=true
RUST_LOG=info
