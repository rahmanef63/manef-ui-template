# =========================
# App URLs
# =========================
HOSTED_URL=https://gg.rahmanef.com
NEXTAUTH_URL=https://gg.rahmanef.com

# =========================
# Convex
# =========================
# Backend repo/domain:
# - repo: rahmanef63/manef-db
# - public endpoint: https://dbgg.rahmanef.com
NEXT_PUBLIC_CONVEX_URL=https://dbgg.rahmanef.com
# Optional server-side override for local dev if dbgg TLS is not trusted yet.
# Example: https://your-deployment.convex.cloud
CONVEX_SERVER_URL=
# Custom JWT bridge for browser -> Convex auth. Required in production.
CONVEX_AUTH_AUDIENCE=manef-ui
CONVEX_AUTH_PRIVATE_KEY=

# =========================
# Auth (NextAuth)
# =========================
# Generate once, keep stable across deploys:
# openssl rand -base64 32
AUTH_SECRET=replace-with-strong-random-secret
AUTH_TRUST_HOST=true

# Device fingerprint salt for login/device approval flow
AUTH_DEVICE_SALT=replace-with-random-salt

# =========================
# OpenClaw integration
# =========================
OPENCLAW_SHARED_SECRET=replace-with-shared-secret
OPENCLAW_ALLOWED_CLOCK_SKEW_SECONDS=300
OPENCLAW_NONCE_TTL_SECONDS=300
OPENCLAW_WORKFLOW_URL=

# =========================
# Docker/Compose optional
# =========================
APP_IMAGE=openclaw-dashbaord-manef-obeant:latest
