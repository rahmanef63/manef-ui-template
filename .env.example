# Convex
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# Auth (NextAuth) — no external service needed
AUTH_SECRET=your-random-secret-here  # generate with: openssl rand -base64 32
AUTH_ADMIN_EMAIL=admin@example.com
AUTH_ADMIN_PASSWORD=changeme
AUTH_ADMIN_NAME=admin
AUTH_ADMIN_ROLES=admin
AUTH_DEVICE_SALT=replace-me-with-a-random-salt
OPENCLAW_SHARED_SECRET=replace-me-with-shared-secret
OPENCLAW_ALLOWED_CLOCK_SKEW_SECONDS=300
OPENCLAW_NONCE_TTL_SECONDS=300
OPENCLAW_WORKFLOW_URL=

# Optional: for email invite features
RESEND_API_KEY=

# App
HOSTED_URL=https://yourdomain.com
